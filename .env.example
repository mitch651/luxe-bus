# Supabase - for reviews + quote backup (see supabase-quote-requests-setup.sql)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# n8n - AI Agent quote automation webhook (add in Netlify env vars for production)
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/luxebus-quote
